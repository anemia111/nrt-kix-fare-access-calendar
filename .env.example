# ============================================================================
# 環境変数のサンプル。
#
# このファイルをコピーして .env.local を作り、値を設定してください。
#   cp .env.example .env.local
#
# .env / .env.local は .gitignore で除外されており、コミットされません。
#
# 【最重要】APIキーはこのファイル（フロントエンド側）に置きません。
# SerpApi と Google Maps のキーは Cloudflare Worker の Secrets にのみ登録します。
#   npx wrangler secret put SERPAPI_API_KEY     --config worker/wrangler.toml
#   npx wrangler secret put GOOGLE_MAPS_API_KEY --config worker/wrangler.toml
#
# NEXT_PUBLIC_ を付けた変数はビルド時にクライアントのJavaScriptへ埋め込まれ、
# ブラウザから誰でも読めます。キーには絶対に付けないでください。
# （ビルド成果物にキーが混入していないことは tests/buildArtifact.test.ts で検証）
# ============================================================================

# ---------------------------------------------------------------------------
# フロントエンド（GitHub Pages に配信される。秘密情報は置かない）
# ---------------------------------------------------------------------------

# Cloudflare Worker のURL。これは秘密情報ではないため公開してよい。
# 未設定の場合、実データ検索は行わず「実価格検索プロバイダーが設定されていません」
# と表示します（デモデータへは切り替えません）。
# 例: https://nrt-kix-api.<あなたのサブドメイン>.workers.dev
NEXT_PUBLIC_API_BASE_URL=

# GitHub Pages はプロジェクトサイトを /<リポジトリ名>/ 配下で配信するため必要。
# ローカル開発では未設定（空）にしてください。
# NEXT_PUBLIC_BASE_PATH=/nrt-kix-fare-access-calendar

# demo = デモデータ / live = 実データ（デモバナーの出し分けにのみ使用）
NEXT_PUBLIC_DATA_MODE=demo

# ---------------------------------------------------------------------------
# Cloudflare Worker 側（wrangler secret put で登録。ここには書かない）
# ---------------------------------------------------------------------------
# SERPAPI_API_KEY       … SerpApi のAPIキー（航空券検索）
# GOOGLE_MAPS_API_KEY   … Google Maps Platform のAPIキー（Routes API / 公共交通）
#
# 公開してよい設定は worker/wrangler.toml の [vars] にあります:
#   ALLOWED_ORIGINS, FLIGHT_CACHE_TTL_SECONDS, TRANSIT_CACHE_TTL_SECONDS

# ---------------------------------------------------------------------------
# 参考（現在は未使用）
# ---------------------------------------------------------------------------
# 価格スナップショットの履歴を永続化する場合のみ。未設定でも動作します。
DATABASE_URL=

APP_BASE_URL=http://localhost:3000
