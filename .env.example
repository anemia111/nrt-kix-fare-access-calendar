# ============================================================================
# 環境変数のサンプル。
#
# このファイルをコピーして .env.local を作り、値を設定してください。
#   cp .env.example .env.local
#
# .env / .env.local は .gitignore で除外されており、コミットされません。
#
# 【重要】APIキーには絶対に NEXT_PUBLIC_ を付けないでください。
# NEXT_PUBLIC_ を付けた変数はビルド時にクライアントのJavaScriptへ埋め込まれ、
# ブラウザの開発者ツールから誰でも見えてしまいます。
# APIキーはサーバー側からのみ読み込みます。
# ============================================================================

# ---------------------------------------------------------------------------
# データモード（クライアントにも公開される。キーではないので NEXT_PUBLIC_ でよい）
# ---------------------------------------------------------------------------
# demo = デモデータ（既定）/ live = 実データ
# 画面の「デモデータです」バナーの出し分けに使います。
NEXT_PUBLIC_DATA_MODE=demo

# GitHub Pages はプロジェクトサイトを /<リポジトリ名>/ 配下で配信するため必要。
# ローカル開発では未設定（空）にしてください。
# NEXT_PUBLIC_BASE_PATH=/nrt-kix-fare-access-calendar

# ---------------------------------------------------------------------------
# 航空券API（サーバー側のみ。現在は未実装のためデモで動作します）
# ---------------------------------------------------------------------------
# mock = デモデータ（既定）/ duffel = Duffel
FLIGHT_PROVIDER=mock
# Duffel の live トークン。test トークンは架空データ（Duffel Airways）を返すため
# 実データにはなりません。
FLIGHT_API_KEY=

# ---------------------------------------------------------------------------
# 鉄道経路API（サーバー側のみ。現在は未実装のためデモで動作します）
# ---------------------------------------------------------------------------
# mock = デモデータ（既定）/ ekispert = 駅すぱあと API
TRANSIT_PROVIDER=mock
# 駅すぱあと API のアクセスキー。
# フリープランには経路探索が含まれないため、経路探索を含むプランが必要です。
TRANSIT_API_KEY=

# ---------------------------------------------------------------------------
# データベース（任意）
# ---------------------------------------------------------------------------
# 価格スナップショットの履歴を永続化する場合に設定します。
# 未設定でもアプリは動作します（履歴は保存されません）。
# 例: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# ---------------------------------------------------------------------------
# アプリのベースURL
# ---------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
